{
  "name": "selivery/enterprise-sdk-php",
  "description": "Official PHP SDK for Selivery Enterprise API",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": "^8.2",
    "ext-json": "*",
    "guzzlehttp/guzzle": "^7.9",
    "psr/simple-cache": "^3.0",
    "ext-openssl": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5",
    "phpstan/phpstan": "^1.11",
    "friendsofphp/php-cs-fixer": "^3.49",
    "php-parallel-lint/php-parallel-lint": "^1.4"
  },
  "autoload": {
    "psr-4": {
      "Selivery\\Enterprise\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Selivery\\Enterprise\\Tests\\": "tests/",
      "Psr\\SimpleCache\\": "tests/_stubs/Psr/SimpleCache/"
    }
  },
  "scripts": {
    "test": "vendor/bin/phpunit",
    "lint": "@php -d error_reporting='E_ALL & ~E_DEPRECATED & ~E_USER_DEPRECATED' vendor/bin/php-cs-fixer fix --dry-run --diff",
    "fix": "vendor/bin/php-cs-fixer fix",
    "stan": "vendor/bin/phpstan analyse src --level=max",
    "lint:syntax": "vendor/bin/parallel-lint -j 4 src tests",
    "check": [
      "@lint",
      "@lint:syntax",
      "@stan",
      "@test"
    ],
    "audit": "composer audit",
    "commit-push": "bash bin/commit-push"
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
